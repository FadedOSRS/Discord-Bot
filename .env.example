DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
DEFAULT_PREFIX=!
DATA_DIR=./data

# Terpinheimer clan site — POST /api/custom-events (same secret as site CLAN_EVENTS_SECRET)
# Use the site origin only (no /#/events — the bot strips #fragments if you paste a SPA URL)
# TERPINHEIMER_SITE_URL=https://terpinheimercc.onrender.com
# TERPINHEIMER_EVENTS_SECRET=
# If the site uses DISCORD_EVENTS_WEBHOOK_URL, set true to avoid duplicate embeds from the bot:
# TERPINHEIMER_SKIP_CHANNEL_POST=true

# HTTP staff dashboard (same process as the bot). Default 3847. Set to 0 to disable.
DASHBOARD_PORT=3847
# Optional: bind address (default 127.0.0.1 — local only)
# DASHBOARD_HOST=0.0.0.0
# Discord OAuth (owner-only dashboard login)
# DASHBOARD_DISCORD_CLIENT_ID=
# DASHBOARD_DISCORD_CLIENT_SECRET=
# DASHBOARD_DISCORD_REDIRECT_URI=http://127.0.0.1:3847/auth/discord/callback
# DASHBOARD_OWNER_DISCORD_ID=
# DASHBOARD_SESSION_SECRET=
